
# make sxhkd reload its configuration files:
super + Escape
	pkill -USR1 -x sxhkd

#
# bspwm hotkeys
#

# quit/restart bspwm
#super + alt + {q,r}
#	bspc {quit,wm -r}

super + alt + r 
	bspc wm -r
super + alt + q 
	bspc quit



# toggle bar 
super + alt + p 
	pkill polybar
super + alt + shift + p 
	polybar &

super + alt + b 
	pkill picom && picom --experimental-backend --config ~/.config/picom/picom.conf -b &

#
# close and kill
alt + F4
	bspc node -{c,k}

# alternate between the tiled and monocle layout
#super + shift + m
#	bspc desktop -l next

# send the newest marked node to the newest preselected node
super + shift + y
	bspc node newest.marked.local -n newest.!automatic.local

# swap the current node and the biggest window
super + shift + g
	bspc node -s biggest.window

#
# state/flags
#

# set the window state
super + {t,shift + t,s,f}
	bspc node -t {tiled,pseudo_tiled,floating,fullscreen}

# set the node flags
super + ctrl + {m,x,y,z}
	bspc node -g {marked,locked,sticky,private}

#
# focus/swap
#

# focus the node in the given direction
super + shift + {h,j,k,l}
	bspc node -{f,s} {west,south,north,east}

# focus the node for the given path jump
super + shift + {p,b,comma,period}
	bspc node -f @{parent,brother,first,second}

# focus the next/previous window in the current desktop
super + shift + c
	bspc node -f {next,prev}.local.!hidden.window

# focus the next/previous desktop in the current monitor
super + bracket{left,right}
	bspc desktop -f {prev,next}.local

# focus the last node/desktop
super + {grave,Tab}
	bspc {node,desktop} -f last

# focus the older or newer node in the focus history
super + shift + {o,i}
	bspc wm -h off; \
	bspc node {older,newer} -f; \
	bspc wm -h on

# focus or send to the given desktop
super + ampersand
    bspc desktop -f ^1
super + eacute
    bspc desktop -f ^2
super + quotedbl
    bspc desktop -f ^3
super + apostrophe
    bspc desktop -f ^4
super + parenleft
    bspc desktop -f ^5
super + section
    bspc desktop -f ^6
super + egrave
    bspc desktop -f ^7
super + exclam
    bspc desktop -f ^8
super + ccedilla
    bspc desktop -f ^9
super + agrave
    bspc desktop -f ^10

super + shift + ampersand
    bspc node -d ^1
super + shift + eacute
    bspc node -d ^2
super + shift + quotedbl
    bspc node -d ^3
super + shift + apostrophe
    bspc node -d ^4
super + shift + parenleft
    bspc node -d ^5
super + shift + section
    bspc node -d ^6
super + shift + egrave
    bspc node -d ^7
super + shift + exclam
    bspc node -d ^8
super + shift + ccedilla
    bspc node -d ^9
super + shift + agrave
    bspc node -d ^10


#super + shift +{1-9,0}
#	bspc {desktop -f,node -d} '^{1-9,10}'

#
# preselect
#

# preselect the direction
super + ctrl + {h,j,k,l}
	bspc node -p {west,south,north,east}

# preselect the ratio
super + ctrl + {1-9}
	bspc node -o 0.{1-9}

# cancel the preselection for the focused node
super + ctrl + space
	bspc node -p cancel

# cancel the preselection for the focused desktop
super + ctrl + shift + space
	bspc query -N -d | xargs -I id -n 1 bspc node id -p cancel

#
# move/resize
#

# expand a window by moving one of its side outward
super + alt + {h,j,k,l}
	bspc node -z {left -20 0,bottom 0 20,top 0 -20,right 20 0}

# contract a window by moving one of its side inward
super + alt + shift + {h,j,k,l}
	bspc node -z {right -20 0,top 0 20,bottom 0 -20,left 20 0}

# move a floating window
super + {Left,Down,Up,Right}
	bspc node -v {-20 0,0 20,0 -20,20 0}

# fullscreen for float 
super + shift + f 
	bspc node -f fullscreen

#
# Utils 
# 


# Volume up
XF86AudioRaiseVolume
    amixer set Speaker 5%+
# Volume down
XF86AudioLowerVolume
    amixer set Speaker 5%-
# Mute / unmute
XF86AudioMute
    amixer set Speaker toggle

# Brightness up
XF86MonBrightnessUp
    brightnessctl set +5%

# Brightness down
XF86MonBrightnessDown
    brightnessctl set 5%-

# Screenshot
Print 
	~/utils/copy_screenshot.sh

# Change wallpaper
super + shift + w 
	~/.config/video-wallpapers/setwall

#
# Apps 
# 

super + Return
	kitty

super + c 
	google-chrome --profile-directory="Default" &

super + m 
	~/apps/LMStudio/LM-Studio-0.4.18-1-x64.AppImage &

super + h 
	kitty htop 

super + d
	nautilus

super + n 
	google-chrome-stable --ozone-platform=x11 netflix.com/browse

super + g 
	google-chrome github.com/login

super + u 
	~/lauchVP.sh

super + l 
	~/utils/screenlock.sh 

super + y 
	xdg-open "steam://open/main"

#
# System 
# 

super + shift + r 
	systemctl reboot

super + shift + Delete
	systemctl poweroff

super + alt + Delete
	systemctl suspend
